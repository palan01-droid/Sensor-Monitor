# ===== REQUIRED FOR PRODUCTION =====
# Get from Groq console: https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# Get from Supabase dashboard: https://app.supabase.com
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-generate-with-secrets.token_hex-32

# Database URL (local dev uses SQLite; production uses PostgreSQL)
# Local: sqlite:///sensor_monitor.db (auto-created)
# Prod: postgresql://user:password@host:5432/dbname
DATABASE_URL=postgresql://...

# ===== OPTIONAL =====
# Set to 1 for local development (disables secure cookies, shows debug info)
FLASK_DEBUG=0

# Override session cookie security (defaults to "not FLASK_DEBUG")
SESSION_COOKIE_SECURE=

# API key for HTTP ingest endpoint (/api/ingest)
# Protects boards from sending data without authentication
DEVICE_API_KEY=your-device-key-here

# Serial port for Arduino/ESP32 connection
# macOS: /dev/cu.usbserial-XXXXX
# Linux: /dev/ttyUSB0
# Windows: COM3
SERIAL_PORT=

# Serial baud rate (default 115200 for most boards)
BAUD_RATE=115200

# Port to run Flask server on
PORT=5000
