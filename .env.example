# Groq API Configuration
GROQ_API_KEY=your_groq_api_key_here

# Serial Port Configuration (optional)
# Set this to your Arduino/ESP32 port if using real hardware
# Examples: /dev/ttyUSB0 (Linux), /dev/cu.usbserial-XXXXX (Mac), COM3 (Windows)
SERIAL_PORT=

# Flask Server Port (default: 5000)
PORT=5000

# Baud Rate for Serial Communication (default: 115200)
BAUD_RATE=115200
