# =============================================================
# SensorMonitor — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================

# ------------------------------------------------------------
# REQUIRED — app will not start without these in production
# ------------------------------------------------------------

# Flask secret key — generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Set to 0 in production. Set to 1 only for local development.
FLASK_DEBUG=0

# ------------------------------------------------------------
# AI — Groq API (required for AI chat & analysis features)
# Get your key at: https://console.groq.com/keys
# ------------------------------------------------------------
GROQ_API_KEY=

# ------------------------------------------------------------
# AUTH — Supabase (required for user login/signup)
# Get these from your Supabase project dashboard → Settings → API
# Leave blank to run in no-auth local dev mode.
# ------------------------------------------------------------
SUPABASE_URL=
SUPABASE_ANON_KEY=

# ------------------------------------------------------------
# HARDWARE — Arduino / ESP32 (optional)
# Serial port for a USB-connected board.
# Examples: /dev/ttyUSB0 (Linux), /dev/cu.usbserial-XXXXX (Mac), COM3 (Windows)
# Leave blank to use simulation mode.
# WiFi boards should POST to /api/ingest with X-API-Key header instead.
# ------------------------------------------------------------
SERIAL_PORT=
BAUD_RATE=115200

# API key that Arduino/ESP32 WiFi boards must send in X-API-Key header.
# Generate with: python -c "import secrets; print(secrets.token_hex(24))"
# Leave blank to disable per-device auth (not recommended in production).
DEVICE_API_KEY=

# ------------------------------------------------------------
# DATABASE (optional — defaults to local SQLite)
# Set to a PostgreSQL URL in production.
# Railway / Heroku provide this automatically as DATABASE_URL.
# Format: postgresql://user:password@host:port/dbname
# ------------------------------------------------------------
DATABASE_URL=

# ------------------------------------------------------------
# SERVER
# ------------------------------------------------------------
PORT=5000

# Comma-separated list of allowed CORS origins.
# In production, set this to your actual domain:
#   CORS_ALLOWED_ORIGINS=https://yourdomain.com
# Default (*) allows all — fine for local dev, restrict in production.
CORS_ALLOWED_ORIGINS=*

# Seconds between database writes (reduces write load). Default: 5
DB_WRITE_INTERVAL=5

# Cookie security — set to 1 in production (requires HTTPS)
SESSION_COOKIE_SECURE=1
